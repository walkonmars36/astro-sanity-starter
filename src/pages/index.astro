---
import { TEST_MESSAGE_QUERY } from "../sanity/lib/queries";
import { loadQuery } from "../sanity/lib/load-query";
import { getDraftModeProps } from "../sanity/lib/draft-mode";

const { data: testMessage } = await loadQuery<{
  _id: string;
  text: string;
} | null>({
  query: TEST_MESSAGE_QUERY,
  ...getDraftModeProps(Astro.cookies),
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Youth Wellbeing — Hello World</title>
  </head>
  <body>
    <h1>Hello from Sanity</h1>
    {
      testMessage ? (
        <p>{testMessage.text}</p>
      ) : (
        <p>No test message found, check the document is published in Studio.</p>
      )
    }
  </body>
</html>
